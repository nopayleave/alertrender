// EMA support (price above) / resistance (price below) — lines + labels on last bar
// Slope logic: a rising EMA reinforces it as support; a falling EMA reinforces it as
// resistance. Confidence = how strongly the slope backs the current role (hold vs break).
emaAtr = ta.atr(14)

f_emaSrInfo(float emaVal, bool isSupport, int slopeLen, float atrVal) =>
    slope = (emaVal - emaVal[slopeLen]) / slopeLen
    slopeNorm = atrVal > 0 ? slope / atrVal : 0.0
    aligned = isSupport ? slopeNorm : -slopeNorm
    conf = math.round(math.min(95, math.max(5, 50 + aligned * 200)))
    arrow = slopeNorm > 0.02 ? "↑" : slopeNorm < -0.02 ? "↓" : "→"
    [conf, arrow]

