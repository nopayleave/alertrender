ema2SmoothValue = request.security(syminfo.tickerid, htfRes2, ema2[barstate.isrealtime ? 1 : 0], gaps=barmerge.gaps_on)[barstate.isrealtime ? 0 : 1]
ema2Value = ema2Smooth ? ema2SmoothValue : ema2Step

// EMA 1: color 0 #a5d6a7 / color 1 #ab47bc  |  EMA 2: color 0 #80deea / color 1 #2962ff
ema1Color = close > ema1Step ? #a5d6a7 : #ab47bc
ema2Color = close > ema2Step ? #80deea : #2962ff

aboveEma1 = close > ema1Step
aboveEma2 = close > ema2Step
trendIndicator = aboveEma1 and aboveEma2 ? "↑ ↑" :
     not aboveEma1 and not aboveEma2 ? "↓ ↓" :
     aboveEma2 and not aboveEma1 ? "- ↑" :
     aboveEma1 and not aboveEma2 ? "↑ -" : "- -"
plot(showOnChart ? ema1Value : na, title="EMA 1", color=ema1Color, linewidth=2)
plot(showOnChart ? ema2Value : na, title="EMA 2", color=ema2Color, linewidth=2)

// EMA support (price above) / resistance (price below) — lines + labels on last bar
// Slope logic: a rising EMA reinforces it as support; a falling EMA reinforces it as
// resistance. Confidence = how strongly the slope backs the current role (hold vs break).
emaAtr = ta.atr(14)

f_emaSrInfo(float emaVal, bool isSupport, int slopeLen, float atrVal) =>
    slope = (emaVal - emaVal[slopeLen]) / slopeLen
    slopeNorm = atrVal > 0 ? slope / atrVal : 0.0
    aligned = isSupport ? slopeNorm : -slopeNorm
    conf = math.round(math.min(95, math.max(5, 50 + aligned * 200)))
    arrow = slopeNorm > 0.02 ? "↑" : slopeNorm < -0.02 ? "↓" : "→"
    [conf, arrow]

ema1IsSupport = close > ema1Step
ema2IsSupport = close > ema2Step
[ema1Conf, ema1Arrow] = f_emaSrInfo(ema1Value, ema1IsSupport, emaSlopeLen, emaAtr)
[ema2Conf, ema2Arrow] = f_emaSrInfo(ema2Value, ema2IsSupport, emaSlopeLen, emaAtr)

ema1Verb = ema1IsSupport ? "support" : "reject"
ema2Verb = ema2IsSupport ? "support" : "reject"
ema1Hint = ema1Conf <= emaBreakThresh ? " ⚠break" : ""
ema2Hint = ema2Conf <= emaBreakThresh ? " ⚠break" : ""
ema1SrLbl = "EMA " + str.tostring(ema1Length) + " " + ema1Arrow + "  " + str.tostring(ema1Conf) + "% " + ema1Verb + ema1Hint
ema2SrLbl = "EMA " + str.tostring(ema2Length) + " " + ema2Arrow + "  " + str.tostring(ema2Conf) + "% " + ema2Verb + ema2Hint

