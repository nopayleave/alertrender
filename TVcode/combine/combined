    if not na(ema1SrLn)
        line.delete(ema1SrLn)
    if not na(ema2SrLn)
        line.delete(ema2SrLn)
    if not na(ema1SrLblObj)
        label.delete(ema1SrLblObj)
    if not na(ema2SrLblObj)
        label.delete(ema2SrLblObj)

    ema1SrLn := line.new(bar_index - emaSrLen, ema1Value, bar_index, ema1Value, color=ema1Color, width=2, style=line.style_dashed)
    ema2SrLn := line.new(bar_index - emaSrLen, ema2Value, bar_index, ema2Value, color=ema2Color, width=2, style=line.style_dashed)
    ema1SrLblObj := label.new(bar_index, ema1Value, ema1SrLbl, style=label.style_label_left, textcolor=ema1Color, color=color.new(ema1Color, 85), size=size.small)
    ema2SrLblObj := label.new(bar_index, ema2Value, ema2SrLbl, style=label.style_label_left, textcolor=ema2Color, color=color.new(ema2Color, 85), size=size.small)

else if barstate.islast
    if not na(ema1SrLn)
        line.delete(ema1SrLn)
        ema1SrLn := na
    if not na(ema2SrLn)
        line.delete(ema2SrLn)
        ema2SrLn := na
    if not na(ema1SrLblObj)
        label.delete(ema1SrLblObj)
        ema1SrLblObj := na
    if not na(ema2SrLblObj)
        label.delete(ema2SrLblObj)
        ema2SrLblObj := na

t = time("1440", session.extended)
is_first = na(t[1]) and not na(t) or t[1] < t

var float day_high = na
var float day_low = na
// First bar of session only (9:30 / session open) — frozen high/low for "opening range" fallback
var float openingRangeHigh = na
var float openingRangeLow = na

if is_first and barstate.isnew
    day_high := high
    day_low := low
    openingRangeHigh := high
    openingRangeLow := low
else
    day_high := nz(day_high[1], high)
    day_low := nz(day_low[1], low)

if high > day_high
    day_high := high

if low < day_low
    day_low := low

dayRange = day_high - day_low
dayMidpoint = day_low + (dayRange / 2)
rangeStatus = close > dayMidpoint ? "Up Range" : close < dayMidpoint ? "Down Range" : "Mid Range"

dayHigh = day_high
dayLow = day_low

// Session day high / low: white, dashed, thickest line
plot(showOnChart ? day_high : na, title="Day High", color=color.white, linewidth=4, style=plot.style_line, linestyle=plot.linestyle_dashed)
plot(showOnChart ? day_low : na, title="Day Low", color=color.white, linewidth=4, style=plot.style_line, linestyle=plot.linestyle_dashed)

trend = close > vwapValue and ema1Value > ema2Value ? "Bullish" : close < vwapValue and ema1Value < ema2Value ? "Bearish" : "Neutral"

vwapRemark = close > upperBandValue3 ? "UP3+" :
     close > upperBandValue2 ? "UP3" :
