// EMA step + plot value. List MTF for intraday HTF; ta.ema inside security for daily+.
f_emaSec(string tf) =>
    tf == "" ? timeframe.in_seconds() : timeframe.in_seconds(tf)

f_emaStepVal(int len, string tf, bool smooth) =>
    res = tf == "" ? timeframe.period : tf
    chartSec = timeframe.in_seconds()
    resSec = f_emaSec(res)
    if resSec == chartSec
        v = ta.ema(close, len)
        [v, v]
    else if resSec >= 86400
        // TV-style: gaps_on interpolates daily EMA smoothly on lower chart TFs (like timeframe_gaps=true).
        step = request.security(syminfo.tickerid, res, ta.ema(close, len), lookahead=barmerge.lookahead_off)
        sm = request.security(syminfo.tickerid, res, ta.ema(close, len), gaps=barmerge.gaps_on, lookahead=barmerge.lookahead_off)
        val = smooth or chartSec < resSec ? sm : step
        [step, val]
    else
        emaRaw = ta.ema(close, len)
        step = request.security(syminfo.tickerid, res, emaRaw[barstate.isrealtime ? 1 : 0])[barstate.isrealtime ? 0 : 1]
        sm = request.security(syminfo.tickerid, res, emaRaw[barstate.isrealtime ? 1 : 0], gaps=barmerge.gaps_on)[barstate.isrealtime ? 0 : 1]
        val = smooth ? sm : step
        [step, val]

