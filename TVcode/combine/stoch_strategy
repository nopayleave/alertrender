alertcondition(longStochExit or shortStochExit, "Entry Stoch Exit", "Tri Stoch: full exit on S1 vs entry K")
alertcondition(longExitGo or longExitStruct or longExitKd or longExitS2,  "Stoch Long Exit",  "Tri Stoch: long exit")
alertcondition(shortExitGo or shortExitStruct or shortExitKd or shortExitS2, "Stoch Short Exit", "Tri Stoch: short exit")
