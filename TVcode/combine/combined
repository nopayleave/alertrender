//@version=6
indicator(title="OBR + Range", shorttitle="OBR + Range", overlay=true, behind_chart=true)

// =============================================================================
// INPUTS — List (VWAP / EMA / alerts)
// =============================================================================
DISPLAY_GROUP = "Display"
hideAbove5m = input.bool(true, title="Hide Above 5 Minutes", group=DISPLAY_GROUP, tooltip="Hide all indicator visuals and alerts on chart timeframes longer than 5 minutes (daily/weekly always hidden when enabled)")
hideonDWM = input(false, title="Hide VWAP on 1D or Above", group="VWAP Settings", display=display.data_window)
var anchor = input.string(defval="Session", title="Anchor Period",
     options=["Session", "Week", "Month", "Quarter", "Year", "Decade", "Century", "Earnings", "Dividends", "Splits"], group="VWAP Settings")
src = input(title="Source", defval=hlc3, group="VWAP Settings", display=display.data_window)
offset = input.int(0, title="Offset", group="VWAP Settings", minval=0, display=display.data_window)
vwapLineColor = input.color(color.yellow, title="VWAP Line", group="VWAP Settings")

EMA_GROUP = "EMA Settings"
ema1Length = input.int(50, title="EMA 1 Length", group=EMA_GROUP)
ema1Timeframe = input.timeframe("1", title="EMA 1 Timeframe", group=EMA_GROUP, tooltip="Default 1m; change or use chart timeframe as needed")
ema1Smooth = input.bool(false, title="EMA 1 Smooth (vs Step)", group=EMA_GROUP)
ema2Length = input.int(200, title="EMA 2 Length", group=EMA_GROUP)
ema2Timeframe = input.timeframe("1", title="EMA 2 Timeframe", group=EMA_GROUP, tooltip="Default 1m; change or use chart timeframe as needed")
ema2Smooth = input.bool(false, title="EMA 2 Smooth (vs Step)", group=EMA_GROUP)
showEmaSr = input.bool(true, title="Show EMA Support/Resistance Lines", group=EMA_GROUP)
emaSrLen = input.int(20, title="EMA S/R Line Length (bars)", minval=1, group=EMA_GROUP)
emaSlopeLen = input.int(10, title="EMA Slope Lookback (bars)", minval=1, group=EMA_GROUP, tooltip="Bars used to measure EMA slope. Rising EMA reinforces support; falling EMA reinforces resistance.")
emaBreakThresh = input.int(40, title="Break Warning Below (%)", minval=0, maxval=100, group=EMA_GROUP, tooltip="If hold/reject confidence is at or below this, label adds a break warning.")

ALERT_GROUP = "List — Alert Settings"
enableListAlerts = input.bool(true, title="Enable List Webhook Alerts", group=ALERT_GROUP)
listAlertFreqStr = input.string("Once Per Bar Close", title="Alert Frequency",
     options=["Once Per Bar Close", "Once Per Bar", "All"],
     group=ALERT_GROUP,
     tooltip="Once Per Bar Close: Alert when bar closes\nOnce Per Bar: Alert once per bar (any time)\nAll: Alert every time condition is met")

BANDS_GROUP = "Bands Settings"
CALC_MODE_TOOLTIP = "Determines the units used to calculate the distance of the bands. When 'Percentage' is selected, a multiplier of 1 means 1%."
calcModeInput = input.string("Standard Deviation", "Bands Calculation Mode", options=["Standard Deviation", "Percentage"], group=BANDS_GROUP, tooltip=CALC_MODE_TOOLTIP, display=display.data_window)
showBand_1 = input(true, title="", group=BANDS_GROUP, inline="band_1", display=display.data_window)
bandMult_1 = input.float(1.0, title="Bands Multiplier #1", group=BANDS_GROUP, inline="band_1", step=0.5, minval=0, display=display.data_window)
showBand_2 = input(true, title="", group=BANDS_GROUP, inline="band_2", display=display.data_window)
bandMult_2 = input.float(2.0, title="Bands Multiplier #2", group=BANDS_GROUP, inline="band_2", step=0.5, minval=0, display=display.data_window)
showBand_3 = input(true, title="", group=BANDS_GROUP, inline="band_3", display=display.data_window)
bandMult_3 = input.float(3.0, title="Bands Multiplier #3", group=BANDS_GROUP, inline="band_3", step=0.5, minval=0, display=display.data_window)

BANDS_COLOR_GROUP = "VWAP Band Colors"
showBandFills = input.bool(true, title="Show Band Background Fills", group=BANDS_COLOR_GROUP)
bandFillTransp = input.int(88, title="Background Transparency", minval=0, maxval=100, group=BANDS_COLOR_GROUP, tooltip="0 = solid, 100 = invisible")
bandLineTransp = input.int(50, title="Band Line Transparency", minval=0, maxval=100, group=BANDS_COLOR_GROUP)
band1UpLine = input.color(#4caf50, title="B1 Upper Line", group=BANDS_COLOR_GROUP, inline="b1l")
band1LoLine = input.color(#f23645, title="B1 Lower Line", group=BANDS_COLOR_GROUP, inline="b1l")
band1UpFill = input.color(#4caf50, title="B1 Upper BG", group=BANDS_COLOR_GROUP, inline="b1bg")
band1LoFill = input.color(#f23645, title="B1 Lower BG", group=BANDS_COLOR_GROUP, inline="b1bg")
band1ChannelFill = input.color(#4caf50, title="B1 Channel BG", group=BANDS_COLOR_GROUP, inline="b1ch")
band2UpLine = input.color(#70ccbd, title="B2 Upper Line", group=BANDS_COLOR_GROUP, inline="b2l")
band2LoLine = input.color(#f48fb1, title="B2 Lower Line", group=BANDS_COLOR_GROUP, inline="b2l")
band2UpFill = input.color(#70ccbd, title="B2 Upper BG", group=BANDS_COLOR_GROUP, inline="b2bg")
band2LoFill = input.color(#f48fb1, title="B2 Lower BG", group=BANDS_COLOR_GROUP, inline="b2bg")
band2ChannelFill = input.color(#70ccbd, title="B2 Channel BG", group=BANDS_COLOR_GROUP, inline="b2ch")
band3UpLine = input.color(#00897b, title="B3 Upper Line", group=BANDS_COLOR_GROUP, inline="b3l")
band3LoLine = input.color(#e91e63, title="B3 Lower Line", group=BANDS_COLOR_GROUP, inline="b3l")
band3UpFill = input.color(#00897b, title="B3 Upper BG", group=BANDS_COLOR_GROUP, inline="b3bg")
band3LoFill = input.color(#e91e63, title="B3 Lower BG", group=BANDS_COLOR_GROUP, inline="b3bg")
band3ChannelFill = input.color(#00897b, title="B3 Channel BG", group=BANDS_COLOR_GROUP, inline="b3ch")

// =============================================================================
// INPUTS — OBR (session ORB / previous levels / webhook)
// =============================================================================
inputMax = input.int(15, title="ORB Duration (minutes)", group="📦 Session ORB Settings 📦")
show_ny_orb = input.bool(true, title="Show New York ORB", group="📦 Session ORB Settings 📦")
nyORB = input.session("0930-0945", title="New York ORB Time", group="📦 Session ORB Settings 📦")
nySession = input.session("0930-1600", title="New York Session Time", group="📦 Session ORB Settings 📦")
show_50pct_line = input.bool(true, title="Show 50% ORB Midline", group="📦 Session ORB Settings 📦")
ny_fill_color = input.color(color.rgb(128, 128, 128, 50), title="New York ORB Color", group="📦 Session ORB Settings 📦")

OBR_ALERT_GROUP = "🔔 OBR Webhook Alerts"
enableObrWebhook = input.bool(true, title="Enable OBR Webhook Alerts", group=OBR_ALERT_GROUP)
obrWebhookFrequency = input.string("Once Per Bar Close", title="Alert Frequency", options=["Once Per Bar Close", "Once Per Bar", "All"], group=OBR_ALERT_GROUP)

PREV_GROUP = "🔙 Previous Levels 🔙"
show_prev_daily = input.bool(true, title="Show Previous Daily High/Low/Open", group=PREV_GROUP)
show_prev_4h = input.bool(true, title="Show Previous 4H High/Low", group=PREV_GROUP)

obrAlertFreq = obrWebhookFrequency == "Once Per Bar Close" ? alert.freq_once_per_bar_close :
     obrWebhookFrequency == "Once Per Bar" ? alert.freq_once_per_bar :
     alert.freq_all

// =============================================================================
// Chart timeframe gate (≤5m intraday when hideAbove5m enabled)
// =============================================================================
timeframeMinutes = timeframe.in_seconds() / 60.0
showOnChart = not hideAbove5m or (timeframe.isintraday and timeframeMinutes <= 5)
showVwapOnChart = showOnChart and not (hideonDWM and timeframe.isdwm)
bandFillDisplay = showBandFills ? display.all : display.none

// =============================================================================
// List: volume check
// =============================================================================
if barstate.islast and ta.cum(volume) == 0
    runtime.error("No volume is provided by the data vendor.")

// =============================================================================
// List: VWAP + bands
// =============================================================================
new_earnings = request.earnings(syminfo.tickerid, earnings.actual, barmerge.gaps_on, barmerge.lookahead_on, ignore_invalid_symbol=true)
new_dividends = request.dividends(syminfo.tickerid, dividends.gross, barmerge.gaps_on, barmerge.lookahead_on, ignore_invalid_symbol=true)
new_split = request.splits(syminfo.tickerid, splits.denominator, barmerge.gaps_on, barmerge.lookahead_on, ignore_invalid_symbol=true)

isNewPeriod = switch anchor
    "Earnings"  => not na(new_earnings)
    "Dividends" => not na(new_dividends)
    "Splits"    => not na(new_split)
    "Session"   => timeframe.change("D")
    "Week"      => timeframe.change("W")
    "Month"     => timeframe.change("M")
    "Quarter"   => timeframe.change("3M")
    "Year"      => timeframe.change("12M")
    "Decade"    => timeframe.change("12M") and year % 10 == 0
    "Century"   => timeframe.change("12M") and year % 100 == 0
    => false

isEsdAnchor = anchor == "Earnings" or anchor == "Dividends" or anchor == "Splits"
if na(src[1]) and not isEsdAnchor
    isNewPeriod := true

float vwapValue = na
float upperBandValue1 = na
float lowerBandValue1 = na
float upperBandValue2 = na
float lowerBandValue2 = na
float upperBandValue3 = na
float lowerBandValue3 = na

if showVwapOnChart
    [_vwap, _stdevUpper, _] = ta.vwap(src, isNewPeriod, 1)
    vwapValue := _vwap
    stdevAbs = _stdevUpper - _vwap
    bandBasis = calcModeInput == "Standard Deviation" ? stdevAbs : _vwap * 0.01
    upperBandValue1 := _vwap + bandBasis * bandMult_1
    lowerBandValue1 := _vwap - bandBasis * bandMult_1
    upperBandValue2 := _vwap + bandBasis * bandMult_2
    lowerBandValue2 := _vwap - bandBasis * bandMult_2
    upperBandValue3 := _vwap + bandBasis * bandMult_3
    lowerBandValue3 := _vwap - bandBasis * bandMult_3

// =============================================================================
// OBR: New York ORB window (calc first — fill plots declared before band fills = lowest z-order in indicator)
// =============================================================================
hide = showOnChart and timeframe.isintraday and timeframeMinutes <= inputMax

t_ny = time(timeframe.period, nyORB + ":1234567")
t_ny_session = time(timeframe.period, nySession + ":1234567")

in_ny = not na(t_ny)
in_ny_session = not na(t_ny_session)

is_first_ny = in_ny and not in_ny[1]

var float ny_high = na
var float ny_low = na

if is_first_ny
    ny_high := high
    ny_low := low
else
    ny_high := ny_high[1]
    ny_low := ny_low[1]
if high > ny_high and in_ny
    ny_high := high
if low < ny_low and in_ny
    ny_low := low

// ORB range background: declared before VWAP band fills = underneath band fills within this indicator.
// indicator(..., behind_chart=true): entire script (fills, VWAP, bands, EMAs, etc.) draws behind candlesticks.
pNyHighFill = plot(hide and in_ny_session and show_ny_orb ? ny_high : na, style=plot.style_line, color=color.new(color.gray, 100), title="New York ORB High (fill ref)", linewidth=1, display=display.none, editable=false)
pNyLowFill = plot(hide and in_ny_session and show_ny_orb ? ny_low : na, style=plot.style_line, color=color.new(color.gray, 100), title="New York ORB Low (fill ref)", linewidth=1, display=display.none, editable=false)
fill(pNyHighFill, pNyLowFill, title="New York ORB Range (background)", color=ny_fill_color, display=show_ny_orb ? display.all : display.none)

alertcondition(showOnChart and ta.crossover(high, ny_high) and in_ny_session and not in_ny, title="New York ORB High Break", message="Price crossed above New York ORB High: {{ticker}} at {{close}}")
alertcondition(showOnChart and ta.crossunder(low, ny_low) and in_ny_session and not in_ny, title="New York ORB Low Break", message="Price crossed below New York ORB Low: {{ticker}} at {{close}}")

// Lowest z-order: invisible plot refs + fills first (Pine draws in declaration order).
// Visible VWAP/band lines are plotted later so they sit above all fills.
pVwapFill = plot(showVwapOnChart ? vwapValue : na, title="VWAP (fill ref)", color=color.new(color.gray, 100), linewidth=1, offset=offset, display=display.none, editable=false)
upperBand_1Fill = plot(showVwapOnChart ? upperBandValue1 : na, title="Upper #1 (fill ref)", color=color.new(color.gray, 100), linewidth=1, offset=offset, display=display.none, editable=false)
lowerBand_1Fill = plot(showVwapOnChart ? lowerBandValue1 : na, title="Lower #1 (fill ref)", color=color.new(color.gray, 100), linewidth=1, offset=offset, display=display.none, editable=false)
upperBand_2Fill = plot(showVwapOnChart ? upperBandValue2 : na, title="Upper #2 (fill ref)", color=color.new(color.gray, 100), linewidth=1, offset=offset, display=display.none, editable=false)
lowerBand_2Fill = plot(showVwapOnChart ? lowerBandValue2 : na, title="Lower #2 (fill ref)", color=color.new(color.gray, 100), linewidth=1, offset=offset, display=display.none, editable=false)
upperBand_3Fill = plot(showVwapOnChart ? upperBandValue3 : na, title="Upper #3 (fill ref)", color=color.new(color.gray, 100), linewidth=1, offset=offset, display=display.none, editable=false)
lowerBand_3Fill = plot(showVwapOnChart ? lowerBandValue3 : na, title="Lower #3 (fill ref)", color=color.new(color.gray, 100), linewidth=1, offset=offset, display=display.none, editable=false)

// Channel background (upper ↔ lower per band)
fill(upperBand_1Fill, lowerBand_1Fill, title="Band 1 Channel BG", color=color.new(band1ChannelFill, bandFillTransp), display=showBand_1 ? bandFillDisplay : display.none)
fill(upperBand_2Fill, lowerBand_2Fill, title="Band 2 Channel BG", color=color.new(band2ChannelFill, bandFillTransp), display=showBand_2 ? bandFillDisplay : display.none)
fill(upperBand_3Fill, lowerBand_3Fill, title="Band 3 Channel BG", color=color.new(band3ChannelFill, bandFillTransp), display=showBand_3 ? bandFillDisplay : display.none)

// Ring fills: VWAP ↔ band levels (upper / lower stacks)
fill(pVwapFill, upperBand_1Fill, title="Fill VWAP → Upper #1", color=color.new(band1UpFill, bandFillTransp), display=showBand_1 ? bandFillDisplay : display.none)
fill(upperBand_1Fill, upperBand_2Fill, title="Fill Upper #1 → Upper #2", color=color.new(band2UpFill, bandFillTransp), display=showBand_1 and showBand_2 ? bandFillDisplay : display.none)
fill(upperBand_2Fill, upperBand_3Fill, title="Fill Upper #2 → Upper #3", color=color.new(band3UpFill, bandFillTransp), display=showBand_2 and showBand_3 ? bandFillDisplay : display.none)

fill(lowerBand_1Fill, pVwapFill, title="Fill Lower #1 → VWAP", color=color.new(band1LoFill, bandFillTransp), display=showBand_1 ? bandFillDisplay : display.none)
fill(lowerBand_2Fill, lowerBand_1Fill, title="Fill Lower #2 → Lower #1", color=color.new(band2LoFill, bandFillTransp), display=showBand_1 and showBand_2 ? bandFillDisplay : display.none)
fill(lowerBand_3Fill, lowerBand_2Fill, title="Fill Lower #3 → Lower #2", color=color.new(band3LoFill, bandFillTransp), display=showBand_2 and showBand_3 ? bandFillDisplay : display.none)

// =============================================================================
// Shared daily data (List JSON + OBR JSON)
// =============================================================================
currentDayVolume = request.security(syminfo.tickerid, "D", volume, lookahead=barmerge.lookahead_off)
prevDayVolume = request.security(syminfo.tickerid, "D", volume[1], lookahead=barmerge.lookahead_on)
previousClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)
changeFromPrevDay = previousClose != 0 ? ((close - previousClose) / previousClose) * 100 : 0

// =============================================================================
// OBR: Previous day / 4H levels (lines on last bar)
// =============================================================================
prev_daily_high = request.security(syminfo.tickerid, "D", high[1])
prev_daily_low = request.security(syminfo.tickerid, "D", low[1])
prev_daily_open = request.security(syminfo.tickerid, "D", open[1])

prev_4h_high = request.security(syminfo.tickerid, "240", high[1])
prev_4h_low = request.security(syminfo.tickerid, "240", low[1])

var line prevD_hi_ln = na
var line prevD_lo_ln = na
var line prevD_op_ln = na
var label prevD_hi_lbl = na
var label prevD_lo_lbl = na
var label prevD_op_lbl = na

var line prev4h_hi_ln = na
var line prev4h_lo_ln = na
var label prev4h_hi_lbl = na
var label prev4h_lo_lbl = na

len = 5

if barstate.islast and showOnChart
    if not na(prevD_hi_ln)
        line.delete(prevD_hi_ln)
    if not na(prevD_lo_ln)
        line.delete(prevD_lo_ln)
    if not na(prevD_op_ln)
        line.delete(prevD_op_ln)
    if not na(prevD_hi_lbl)
        label.delete(prevD_hi_lbl)
    if not na(prevD_lo_lbl)
        label.delete(prevD_lo_lbl)
    if not na(prevD_op_lbl)
        label.delete(prevD_op_lbl)

    prevD_hi_ln := show_prev_daily ? line.new(bar_index - len, prev_daily_high, bar_index, prev_daily_high, color=color.rgb(255, 255, 255), width=2) : na
    prevD_lo_ln := show_prev_daily ? line.new(bar_index - len, prev_daily_low, bar_index, prev_daily_low, color=color.rgb(255, 255, 255), width=2) : na
    prevD_op_ln := show_prev_daily ? line.new(bar_index - len, prev_daily_open, bar_index, prev_daily_open, color=color.rgb(255, 255, 255), width=2) : na

    prevD_hi_lbl := show_prev_daily ? label.new(bar_index, prev_daily_high, "Prev D High", style=label.style_label_left, textcolor=color.white, color=color.new(color.white, 100), size=size.small) : na
    prevD_lo_lbl := show_prev_daily ? label.new(bar_index, prev_daily_low, "Prev D Low", style=label.style_label_left, textcolor=color.white, color=color.new(color.white, 100), size=size.small) : na
    prevD_op_lbl := show_prev_daily ? label.new(bar_index, prev_daily_open, "Prev D Open", style=label.style_label_left, textcolor=color.white, color=color.new(color.rgb(0, 128, 255), 100), size=size.small) : na

    if not na(prev4h_hi_ln)
        line.delete(prev4h_hi_ln)
    if not na(prev4h_lo_ln)
        line.delete(prev4h_lo_ln)
    if not na(prev4h_hi_lbl)
        label.delete(prev4h_hi_lbl)
    if not na(prev4h_lo_lbl)
        label.delete(prev4h_lo_lbl)

    prev4h_hi_ln := show_prev_4h ? line.new(bar_index - len, prev_4h_high, bar_index, prev_4h_high, color=#ffffff, width=2) : na
    prev4h_lo_ln := show_prev_4h ? line.new(bar_index - len, prev_4h_low, bar_index, prev_4h_low, color=#ffffff, width=2) : na

    prev4h_hi_lbl := show_prev_4h ? label.new(bar_index, prev_4h_high, "Prev 4H High", style=label.style_label_left, textcolor=color.white, color=color.new(color.rgb(0, 255, 0), 100), size=size.small) : na
    prev4h_lo_lbl := show_prev_4h ? label.new(bar_index, prev_4h_low, "Prev 4H Low", style=label.style_label_left, textcolor=color.white, color=color.new(color.rgb(255, 166, 0), 100), size=size.small) : na

else if barstate.islast
    if not na(prevD_hi_ln)
        line.delete(prevD_hi_ln)
        prevD_hi_ln := na
    if not na(prevD_lo_ln)
        line.delete(prevD_lo_ln)
        prevD_lo_ln := na
    if not na(prevD_op_ln)
        line.delete(prevD_op_ln)
        prevD_op_ln := na
    if not na(prevD_hi_lbl)
        label.delete(prevD_hi_lbl)
        prevD_hi_lbl := na
    if not na(prevD_lo_lbl)
        label.delete(prevD_lo_lbl)
        prevD_lo_lbl := na
    if not na(prevD_op_lbl)
        label.delete(prevD_op_lbl)
        prevD_op_lbl := na
    if not na(prev4h_hi_ln)
        line.delete(prev4h_hi_ln)
        prev4h_hi_ln := na
    if not na(prev4h_lo_ln)
        line.delete(prev4h_lo_ln)
        prev4h_lo_ln := na
    if not na(prev4h_hi_lbl)
        label.delete(prev4h_hi_lbl)
        prev4h_hi_lbl := na
    if not na(prev4h_lo_lbl)
        label.delete(prev4h_lo_lbl)
        prev4h_lo_lbl := na

// Visible VWAP + band lines (above band fills + ORB fill)
pVwap = plot(showVwapOnChart ? vwapValue : na, title="VWAP", color=vwapLineColor, linewidth=2, offset=offset)

upperBand_1 = plot(showVwapOnChart ? upperBandValue1 : na, title="Upper Band #1", color=color.new(band1UpLine, bandLineTransp), linewidth=4, offset=offset, display=showBand_1 ? display.all : display.none)
lowerBand_1 = plot(showVwapOnChart ? lowerBandValue1 : na, title="Lower Band #1", color=color.new(band1LoLine, bandLineTransp), linewidth=4, offset=offset, display=showBand_1 ? display.all : display.none)
upperBand_2 = plot(showVwapOnChart ? upperBandValue2 : na, title="Upper Band #2", color=color.new(band2UpLine, bandLineTransp), linewidth=1, offset=offset, display=showBand_2 ? display.all : display.none)
lowerBand_2 = plot(showVwapOnChart ? lowerBandValue2 : na, title="Lower Band #2", color=color.new(band2LoLine, bandLineTransp), linewidth=1, offset=offset, display=showBand_2 ? display.all : display.none)
upperBand_3 = plot(showVwapOnChart ? upperBandValue3 : na, title="Upper Band #3", color=color.new(band3UpLine, bandLineTransp), linewidth=4, offset=offset, display=showBand_3 ? display.all : display.none)
lowerBand_3 = plot(showVwapOnChart ? lowerBandValue3 : na, title="Lower Band #3", color=color.new(band3LoLine, bandLineTransp), linewidth=4, offset=offset, display=showBand_3 ? display.all : display.none)

// ORB high/low edges + 50% (on top of VWAP band fills)
plot(hide and in_ny_session and show_ny_orb ? ny_high : na, style=plot.style_line, color=ny_high[1] != ny_high ? na : #00ff6a00, title="New York ORB High", linewidth=2)
plot(hide and in_ny_session and show_ny_orb ? ny_low : na, style=plot.style_line, color=ny_low[1] != ny_low ? na : #00ff6a00, title="New York ORB Low", linewidth=2)

ny_mid = (ny_high + ny_low) / 2.0

plot(hide and in_ny_session and show_ny_orb and show_50pct_line ? ny_mid : na, style=plot.style_line, color=color.new(color.white, 30), title="New York ORB 50%", linewidth=1, linestyle=plot.linestyle_dashed)

ny_within = not na(ny_high) and not na(ny_low) and close >= ny_low and close <= ny_high
ny_outside_above = not na(ny_high) and close > ny_high
ny_outside_below = not na(ny_low) and close < ny_low
ny_upper_half = ny_within and not na(ny_mid) and close >= ny_mid
ny_lower_half = ny_within and not na(ny_mid) and close < ny_mid

ny_orb_status = ny_outside_above ? "outside_above" : ny_outside_below ? "outside_below" : ny_upper_half ? "within_upper" : ny_lower_half ? "within_lower" : "unknown"

shouldSendObrAlert = enableObrWebhook and (obrWebhookFrequency == "Once Per Bar Close" ? barstate.isconfirmed : true)
if showOnChart and shouldSendObrAlert and in_ny_session and not in_ny and not na(ny_high) and not na(ny_low)
    price_direction = close > close[1] ? "up" : close < close[1] ? "down" : "flat"

    orb_cross_high = ta.crossover(high, ny_high)
    orb_cross_low = ta.crossunder(low, ny_low)
    orb_cross_mid_up = ta.crossover(close, ny_mid)
    orb_cross_mid_down = ta.crossunder(close, ny_mid)
    orb_cross_bottom = ta.crossover(close, ny_low)
    orb_cross_high_down = ta.crossunder(close, ny_high)

    orb_crossover = orb_cross_high ? "cross_high" : orb_cross_low ? "cross_low" : orb_cross_mid_up ? "cross_mid_up" : orb_cross_mid_down ? "cross_mid_down" : orb_cross_bottom ? "cross_bottom" : orb_cross_high_down ? "cross_high_down" : "none"

    obrJsonMsg = '{' +
      '"symbol": "' + syminfo.ticker + '",' +
