// VWAP band zone color: which zone a value sits in, using the band line colors
// > U2 → B3 upper, U1–U2 → B2 upper, VWAP–U1 → B1 upper (mirror below VWAP)
f_vwapZoneColor(float v, color fallback) =>
    na(v) or na(vwapValue) ? fallback :
         v > upperBandValue2 ? band3UpLine :
         v > upperBandValue1 ? band2UpLine :
         v > vwapValue       ? band1UpLine :
         v < lowerBandValue2 ? band3LoLine :
         v < lowerBandValue1 ? band2LoLine :
         band1LoLine

// EMA colors — EMA 1/2: solid/dotted by price position; EMA 3/4/5: always solid, below color when price is below.
