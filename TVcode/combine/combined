[chartEma4Conf, chartEma4Arrow] = f_emaSrInfo(chartEma4Value, aboveChartEma4, emaSlopeLen, emaAtr)
[chartEma5Conf, chartEma5Arrow] = f_emaSrInfo(chartEma5Value, aboveChartEma5, emaSlopeLen, emaAtr)

