//@version=5
strategy("Stochastic 39,5,4 反轉策略 1m - Long/Short 對稱出場", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.04)

// === 參數 ===
lenK = input.int(39, "Stoch %K Length")
smoothK = input.int(5, "%K Smoothing")
smoothD = input.int(4, "%D Smoothing")
diffThreshold = input.float(2.0, "K/D 差值門檻", minval=0.5, step=0.1)
showExitLabels = input.bool(true, "顯示出場原因標籤")
showLongExit   = input.bool(true, "顯示 Long 出場標記")

// === 交易時段 ===
grpSession    = "交易時段"
tradeRTHOnly  = input.bool(true, "僅正常時段交易 (9:30–16:00 ET)", group=grpSession)
useDayRules   = input.bool(true, "啟用每日時段規則", group=grpSession)
entryWindow   = input.session("0930-1430", "入場時段 (14:30 後禁入場)", group=grpSession)
dayExitWindow = input.session("1500-1501", "15:00 全部平倉", group=grpSession)
sessionTZ     = "America/New_York"
inRTH         = not na(time(timeframe.period, "0930-1600", sessionTZ))
inEntryWindow = not na(time(timeframe.period, entryWindow, sessionTZ))
is3pmExit     = not na(time(timeframe.period, dayExitWindow, sessionTZ))
canTrade      = tradeRTHOnly ? inRTH : true
canEnter      = canTrade and (useDayRules ? inEntryWindow : true)

// === 出場過濾 ===
grpExit          = "出場"
exitOnlyIfLosing = input.bool(true, "僅虧損時才 Stoch 出場", group=grpExit,
     tooltip="持倉未虧損（含打平）時，忽略 Stoch 出場訊號")
useStopLoss      = input.bool(true, "啟用止損", group=grpExit)
stopLossPct      = input.float(1.0, "止損 %", minval=0.1, step=0.1, group=grpExit)
positionLosing   = strategy.openprofit < 0
canStochExit     = exitOnlyIfLosing ? positionLosing : true

// === 階梯止盈 ===
grpProfit      = "階梯止盈"
useScaleProfit = input.bool(true, "啟用階梯止盈", group=grpProfit)
ptFirstMove    = input.float(5.0, "首次減倉：價格移動 %", minval=0.1, step=0.1, group=grpProfit)
ptFirstQtyPct  = input.float(50.0, "首次減倉：倉位 %", minval=1, maxval=100, group=grpProfit)
ptStepMove     = input.float(1.0, "後續每移動 %", minval=0.1, step=0.1, group=grpProfit)
ptStepQtyPct   = input.float(10.0, "後續每次減倉 %", minval=1, maxval=100, group=grpProfit)

var float ptEntryPrice   = na
var float ptInitialQty   = na
var int   ptLastScalePct = 0
var float ptLastScalePrice = na

if strategy.position_size == 0
    ptEntryPrice := na
    ptInitialQty := na
    ptLastScalePct := 0
    ptLastScalePrice := na

// === 隨機指標 (標準 39,5,4：K = SMA(stoch,5), D = SMA(K,4)) ===
stochRaw = ta.stoch(close, high, low, lenK)
stochK    = ta.sma(stochRaw, smoothK)
stochD    = ta.sma(stochK, smoothD)

// 畫線
plot(stochK, color=color.blue, title="%K")
plot(stochD, color=color.red, title="%D")
hline(90, "Long 止盈線", color=color.new(color.red, 0))
hline(10, "Short 止盈線", color=color.new(color.green, 0))
hline(80, "超買", color=color.red)
hline(60, "中軸上", color=color.new(color.gray, 50))
hline(40, "中軸下", color=color.new(color.gray, 50))
hline(20, "超賣", color=color.green)

// === 入場條件 ===
grpEntry       = "入場"
enableMidZone  = input.bool(true, "啟用 40-60 中軸入場", group=grpEntry)
midZoneLo      = input.int(40, "中軸下限", minval=0, maxval=100, group=grpEntry)
midZoneHi      = input.int(60, "中軸上限", minval=0, maxval=100, group=grpEntry)
inMidZone      = stochK >= midZoneLo and stochK <= midZoneHi and stochD >= midZoneLo and stochD <= midZoneHi
shortFirstOnly = input.bool(true, "Short 僅首日 crossunder", group=grpEntry,
     tooltip="盤前 crossunder 優先於開盤後第一個；每日只入場一次")
pmStartH       = input.int(4,  "盤前開始 (ET 時)", minval=0, maxval=23, group=grpEntry)
pmStartM       = input.int(0,  "盤前開始 (ET 分)", minval=0, maxval=59, group=grpEntry)
pmEndH         = input.int(9,  "盤前結束 (ET 時)", minval=0, maxval=23, group=grpEntry)
pmEndM         = input.int(30, "盤前結束 (ET 分)", minval=0, maxval=59, group=grpEntry)

curHM     = hour(time, sessionTZ) * 100 + minute(time, sessionTZ)
pmStart   = pmStartH * 100 + pmStartM
pmEnd     = pmEndH * 100 + pmEndM
inPM      = curHM >= pmStart and curHM < pmEnd
isFirstRTH = inRTH and not inRTH[1]

longExtreme    = ta.crossover(stochK, stochD) and stochK > 80 and stochD > 80
longMid        = enableMidZone and ta.crossover(stochK, stochD) and inMidZone
longCondition  = longExtreme or longMid

shortExtreme   = ta.crossunder(stochK, stochD) and stochK < 20 and stochD < 20
shortMid       = enableMidZone and ta.crossunder(stochK, stochD) and inMidZone
shortCondition = shortExtreme or shortMid

dayKey = year(time, sessionTZ) * 10000 + month(time, sessionTZ) * 100 + dayofmonth(time, sessionTZ)
var int  shortDayKey       = na
var bool pmShortCrossToday = false
var bool pmShortWasExtreme = false
var bool shortFirstTaken   = false

if dayKey != shortDayKey
    shortDayKey       := dayKey
    pmShortCrossToday := false
    pmShortWasExtreme := false
    shortFirstTaken   := false

if inPM and shortCondition
    pmShortCrossToday := true
    pmShortWasExtreme := shortExtreme

pmOpenShort   = shortFirstOnly and isFirstRTH and pmShortCrossToday and canEnter and not shortFirstTaken
rthFirstShort = shortFirstOnly and shortCondition and canEnter and not pmShortCrossToday and not shortFirstTaken
legacyShort   = not shortFirstOnly and shortCondition and canEnter
shortEntry    = pmOpenShort or rthFirstShort or legacyShort
shortComment  = pmOpenShort ? (pmShortWasExtreme ? "Short PM OS" : "Short PM Mid") : shortExtreme ? "Short OS" : "Short Mid"

if (longCondition and canEnter)
    strategy.entry("Long", strategy.long, comment=longExtreme ? "Long OB" : "Long Mid")

if shortEntry
    shortFirstTaken := true
    strategy.entry("Short", strategy.short, comment=shortComment)

// === 階梯止盈執行（入場後）===
inLong   = strategy.position_size > 0
inShort  = strategy.position_size < 0
newLong  = inLong and strategy.position_size[1] <= 0
newShort = inShort and strategy.position_size[1] >= 0

if newLong or newShort
    ptEntryPrice := strategy.position_avg_price
    ptInitialQty := math.abs(strategy.position_size)
    ptLastScalePct := 0
    ptLastScalePrice := na

// === 止損 ===
if useStopLoss and not na(strategy.position_avg_price)
    if strategy.position_size > 0
        slPrice = strategy.position_avg_price * (1.0 - stopLossPct / 100.0)
        if low <= slPrice
            strategy.close("Long", comment="SL -" + str.tostring(stopLossPct) + "%")
            if showExitLabels
                label.new(bar_index, slPrice, "SL -" + str.tostring(stopLossPct) + "%",
                     style=label.style_label_up, color=color.new(color.red, 0), textcolor=color.white, size=size.small)
    if strategy.position_size < 0
        slPrice = strategy.position_avg_price * (1.0 + stopLossPct / 100.0)
        if high >= slPrice
            strategy.close("Short", comment="SL -" + str.tostring(stopLossPct) + "%")
            if showExitLabels
                label.new(bar_index, slPrice, "SL -" + str.tostring(stopLossPct) + "%",
                     style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

if useScaleProfit and not na(ptEntryPrice) and not na(ptInitialQty)
    stepPct  = int(math.round(ptStepMove))
    firstPct = int(math.round(ptFirstMove))

    if inLong and strategy.position_size > 0
        favorMove = (high - ptEntryPrice) / ptEntryPrice * 100.0

        if ptLastScalePct < firstPct and favorMove >= ptFirstMove
            exitQty = math.min(ptInitialQty * ptFirstQtyPct / 100.0, strategy.position_size)
            if exitQty > 0
                strategy.close("Long", qty=exitQty, comment="PT " + str.tostring(ptFirstQtyPct, "#") + "% @+" + str.tostring(firstPct) + "%")
            ptLastScalePct := firstPct
            ptLastScalePrice := ptEntryPrice * (1.0 + firstPct / 100.0)
        else if ptLastScalePct >= firstPct and favorMove > ptFirstMove
            maxStepLevel = firstPct + int(math.floor((favorMove - ptFirstMove) / ptStepMove)) * stepPct
            if maxStepLevel > ptLastScalePct
                for lvl = ptLastScalePct + stepPct to maxStepLevel by stepPct
                    if strategy.position_size <= 0
                        break
                    exitQty = math.min(ptInitialQty * ptStepQtyPct / 100.0, strategy.position_size)
                    if exitQty > 0
                        strategy.close("Long", qty=exitQty, comment="PT " + str.tostring(ptStepQtyPct, "#") + "% @+" + str.tostring(lvl) + "%")
                    ptLastScalePct := lvl
                    ptLastScalePrice := ptEntryPrice * (1.0 + lvl / 100.0)

        if not na(ptLastScalePrice) and ptLastScalePct >= firstPct and low <= ptLastScalePrice
            strategy.close("Long", comment="PT 回撤全平 @+" + str.tostring(ptLastScalePct) + "%")
            if showExitLabels
                label.new(bar_index, high, "PT 回撤全平\n+" + str.tostring(ptLastScalePct) + "%",
                     style=label.style_label_down, color=color.new(color.yellow, 0), textcolor=color.black,
                     yloc=yloc.abovebar, size=size.small)

    else if inShort and strategy.position_size < 0
        favorMove = (ptEntryPrice - low) / ptEntryPrice * 100.0

        if ptLastScalePct < firstPct and favorMove >= ptFirstMove
            exitQty = math.min(ptInitialQty * ptFirstQtyPct / 100.0, math.abs(strategy.position_size))
            if exitQty > 0
                strategy.close("Short", qty=exitQty, comment="PT " + str.tostring(ptFirstQtyPct, "#") + "% @+" + str.tostring(firstPct) + "%")
            ptLastScalePct := firstPct
            ptLastScalePrice := ptEntryPrice * (1.0 - firstPct / 100.0)
        else if ptLastScalePct >= firstPct and favorMove > ptFirstMove
            maxStepLevel = firstPct + int(math.floor((favorMove - ptFirstMove) / ptStepMove)) * stepPct
            if maxStepLevel > ptLastScalePct
                for lvl = ptLastScalePct + stepPct to maxStepLevel by stepPct
                    if strategy.position_size >= 0
                        break
                    exitQty = math.min(ptInitialQty * ptStepQtyPct / 100.0, math.abs(strategy.position_size))
                    if exitQty > 0
                        strategy.close("Short", qty=exitQty, comment="PT " + str.tostring(ptStepQtyPct, "#") + "% @+" + str.tostring(lvl) + "%")
                    ptLastScalePct := lvl
                    ptLastScalePrice := ptEntryPrice * (1.0 - lvl / 100.0)

        if not na(ptLastScalePrice) and ptLastScalePct >= firstPct and high >= ptLastScalePrice
            strategy.close("Short", comment="PT 回撤全平 @+" + str.tostring(ptLastScalePct) + "%")
            if showExitLabels
                label.new(bar_index, low, "PT 回撤全平\n+" + str.tostring(ptLastScalePct) + "%",
                     style=label.style_label_up, color=color.new(color.yellow, 0), textcolor=color.black,
                     yloc=yloc.belowbar, size=size.small)

// === Long 出場 ===
// %K 向下穿 90 且 D > K 且 D 仍在 90 上方，或 |K-D| > 2 且 D > K 且 D >= 90
longExit1 = ta.crossunder(stochK, 90) and stochD > stochK and stochD >= 90
longExit2 = (math.abs(stochK - stochD) > diffThreshold) and (stochD > stochK) and stochD >= 90
longExit  = longExit1 or longExit2
longExitReason = longExit1 and longExit2 ? "K↓90 + |K-D|>" + str.tostring(diffThreshold) : longExit1 ? "K↓90 D>K" : "|K-D|>" + str.tostring(diffThreshold) + " D>K"
longExitReason := longExitReason + "\nK=" + str.tostring(stochK, "#.##") + " D=" + str.tostring(stochD, "#.##")
longExitSignal = strategy.position_size > 0 and longExit and canTrade and canStochExit

if longExitSignal
    strategy.close("Long", comment=longExitReason)
    if showExitLabels
        label.new(bar_index, stochK, "Long 出\n" + longExitReason, style=label.style_label_down, color=color.new(color.orange, 0), textcolor=color.white, size=size.small)

plotshape(showLongExit and longExitSignal and longExit1 and not longExit2, title="Long Exit K↓90", style=shape.triangledown, location=location.top, color=color.orange, text="L↓90", textcolor=color.white, size=size.small)
plotshape(showLongExit and longExitSignal and longExit2 and not longExit1, title="Long Exit |K-D|", style=shape.triangledown, location=location.top, color=color.red, text="L|KD|", textcolor=color.white, size=size.small)
plotshape(showLongExit and longExitSignal and longExit1 and longExit2, title="Long Exit Both", style=shape.triangledown, location=location.top, color=color.maroon, text="L both", textcolor=color.white, size=size.small)
plotchar(showLongExit and longExitSignal ? stochK : na, title="Long 出場 @K", char="▼", location=location.absolute, color=color.orange, size=size.tiny)
bgcolor(showLongExit and longExitSignal ? color.new(color.orange, 85) : na, title="Long 出場背景")

// === Short 出場（對稱）===
// %K 向上穿 10 且 K > D 且 D 仍在 10 下方，或 |K-D| > 2 且 K > D 且 D <= 10
shortExit1 = ta.crossover(stochK, 10) and stochK > stochD and stochD <= 10
shortExit2 = (math.abs(stochK - stochD) > diffThreshold) and (stochK > stochD) and stochD <= 10
shortExit  = shortExit1 or shortExit2
shortExitReason = shortExit1 and shortExit2 ? "K↑10 + |K-D|>" + str.tostring(diffThreshold) : shortExit1 ? "K↑10 K>D" : "|K-D|>" + str.tostring(diffThreshold) + " K>D"
shortExitReason := shortExitReason + "\nK=" + str.tostring(stochK, "#.##") + " D=" + str.tostring(stochD, "#.##")

shortExitSignal = strategy.position_size < 0 and shortExit and canTrade and canStochExit

if shortExitSignal
    strategy.close("Short", comment=shortExitReason)
    if showExitLabels
        label.new(bar_index, low, "Short 出\n" + shortExitReason, style=label.style_label_up, color=color.new(color.purple, 0), textcolor=color.white, yloc=yloc.belowbar, size=size.small)

// === 15:00 全部平倉 ===
if useDayRules and is3pmExit and strategy.position_size != 0
    strategy.close_all(comment="15:00 平倉")
    if showExitLabels
        label.new(bar_index, close, "15:00 平倉", style=label.style_label_left,
             color=color.new(color.gray, 0), textcolor=color.white, size=size.small)

// === EMA 過濾（可選）===
ema20 = ta.ema(close, 20)
plot(ema20, color=color.orange, title="EMA 20")

useTrendFilter = input.bool(false, "使用 EMA 趨勢過濾")
if (useTrendFilter)
    longCondition  := longCondition and close > ema20
    shortCondition := shortCondition and close < ema20

// 視覺提示
bgcolor(not canTrade ? color.new(color.gray, 92) : na, title="盤外時段")
bgcolor(canTrade and useDayRules and not inEntryWindow ? color.new(color.gray, 88) : na, title="14:30 後禁入場")
bgcolor(canEnter and longCondition ? color.new(color.green, 85) : na)
bgcolor(canEnter and shortEntry ? color.new(color.red, 85) : na)

// 警報
alertcondition(longExtreme and canEnter, "Long 入場 OB", "Stoch Long 超買區")
alertcondition(longMid and canEnter, "Long 入場 Mid", "Stoch Long 40-60")
alertcondition(shortEntry and shortExtreme, "Short 入場 OS", "Stoch Short 超賣區")
alertcondition(shortEntry and shortMid, "Short 入場 Mid", "Stoch Short 40-60")
alertcondition(pmOpenShort, "Short 開盤 PM", "Stoch Short 盤前 crossunder 開盤入場")
alertcondition(useDayRules and is3pmExit and strategy.position_size != 0, "15:00 平倉", "15:00 全部平倉")
alertcondition(useStopLoss and strategy.position_size > 0 and low <= strategy.position_avg_price * (1.0 - stopLossPct / 100.0), "Long 止損", "Long SL")
alertcondition(useStopLoss and strategy.position_size < 0 and high >= strategy.position_avg_price * (1.0 + stopLossPct / 100.0), "Short 止損", "Short SL")
alertcondition(longExit1 and strategy.position_size > 0 and canTrade and canStochExit, "Long 出場 K↓90", "Long: K↓90 D>K")
alertcondition(longExit2 and strategy.position_size > 0 and not longExit1 and canTrade and canStochExit, "Long 出場 K-D", "Long: |K-D|>門檻 D>K")
alertcondition(shortExit1 and strategy.position_size < 0 and canTrade and canStochExit, "Short 出場 K↑10", "Short: K↑10 K>D")
alertcondition(shortExit2 and strategy.position_size < 0 and not shortExit1 and canTrade and canStochExit, "Short 出場 K-D", "Short: |K-D|>門檻 K>D")